extends _layout.pug

block content
  section.section.is-main-section
    .columns
      .column.is-6.is-offset-3
        .card
          header.card-header
            p.card-header-title
              span.icon
                i.mdi.mdi-account-cog
              | Edit User Credentials: #{targetUser.username}
          .card-content
            form(method="post" action=`/admin/account/${targetUser.username}`)
              .field.is-horizontal
                .field-label.is-normal
                  label.label Username
                .field-body
                  .field
                    .control.has-icons-left
                      input.input(type="text" name="username" placeholder="Username" value=targetUser.username)
                      span.icon.is-small.is-left
                        i.mdi.mdi-account
              .field.is-horizontal
                .field-label.is-normal
                  label.label Country Code
                .field-body
                  .field
                    .control.has-icons-left
                      input.input(type="text" name="countryCode" placeholder="CL, AR, US, etc. (Leave blank for none)" value=targetUser.countryCode || '')
                      span.icon.is-small.is-left
                        i.mdi.mdi-earth
              .field.is-horizontal
                .field-label.is-normal
                  label.label New Password
                .field-body
                  .field
                    .control.has-icons-left
                      input.input(type="password" name="password" placeholder="Leave blank to keep current")
                      span.icon.is-small.is-left
                        i.mdi.mdi-lock
              .field.is-grouped.is-grouped-right
                .control.is-expanded
                  if formMessage
                    if formMessage.danger
                      .notification.is-danger.is-light #{formMessage.message}
                    else
                      .notification.is-success.is-light #{formMessage.message}
                .control
                  button.button.is-link(type="submit")
                    span.icon.is-small
                      i.mdi.mdi-content-save
                    span Save
