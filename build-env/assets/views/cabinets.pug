extends _layout.pug

block content
  section.section.is-main-section
    if error
      .notification.is-danger.is-light #{error}
    if success
      .notification.is-success.is-light #{success}

    .columns
      .column.is-12
        .card.mb-6
          header.card-header
            p.card-header-title
              span.icon
                i.mdi.mdi-gamepad-variant
              | Cabinets Management
            if !admin
              p.card-header-icon
                span.tag.is-info.is-medium Slots: #{cabinetCount} / 10
          .card-content
            .content
              article.message.is-info
                .message-body
                  p
                    strong Important:
                    |  You only need 
                    strong ONE PCBID
                    |  for all your games. You do not need to generate a separate PCBID for each game. Use the same PCBID across all your game clients.
                  p.mt-2
                    strong EA Service URL:
                    code#ea-service-url.ml-2 http://ea.ryu7w7.xyz/service/init
                    button.button.is-small.is-light.ml-2(onclick="copyToClipboard('http://ea.ryu7w7.xyz/service/init', this)" data-tooltip="Copy URL")
                      span.icon.is-small
                        i.mdi.mdi-content-copy
              p A Cabinet represents an arcade machine or game client. To play online with RyuNET, your game client must send a PCBID that is registered here.
              if cabinetCount < 10 || admin
                form(method="post" action="/cabinets/new")
                  .field.has-addons
                    if admin
                      .control
                        .select
                          select(name="targetUsername")
                            each u in users
                              option(value=u selected=u===user) #{u}
                    .control.is-expanded
                      input.input(type="text" name="name" placeholder="Cabinet Name (e.g., SDVX Local)" required)
                    .control
                      button.button.is-info(type="submit")
                        span.icon
                          i.mdi.mdi-plus
                        | Add New Cabinet
              else
                p.has-text-danger You have reached the maximum limit of 10 cabinets.
            
            .table-container.mt-4
              table.table.is-fullwidth.is-striped.is-hoverable
                thead
                  tr
                    th Cabinet Name
                    th PCBID (srcid)
                    if admin
                      th Owner
                    th Last Seen
                    th Actions
                tbody
                  if cabinets.length === 0
                    tr
                      td.has-text-centered(colspan=admin ? 5 : 4) No cabinets found. 
                  else
                    each cab in cabinets
                      tr
                        td #{cab.name}
                        td
                          code #{cab.pcbid}
                          button.button.is-small.is-light.is-borderless.ml-2(onclick=`copyToClipboard('${cab.pcbid}', this)` data-tooltip="Copy PCBID")
                            span.icon.is-small
                              i.mdi.mdi-content-copy
                        if admin
                          td
                            span.tag.is-light #{cab.username}
                        td
                          if cab.lastSeen === 0
                            span.has-text-grey Never
                          else
                            - var date = new Date(cab.lastSeen)
                            | #{date.toLocaleString()}
                        td
                          .buttons
                            button.button.is-small.is-warning.is-light(onclick=`renameCabinet("${cab.pcbid}", "${cab.name}")` data-tooltip="Rename")
                              span.icon.is-small
                                i.mdi.mdi-pencil
                            form(method="post" action="/cabinets/delete" onsubmit="return confirm('Are you sure you want to delete this cabinet?');" style="display:inline;")
                              input(type="hidden" name="pcbid" value=cab.pcbid)
                              button.button.is-small.is-danger.is-light(type="submit" data-tooltip="Delete")
                                span.icon.is-small
                                  i.mdi.mdi-trash-can

    form#rename-form(method="post" action="/cabinets/rename")
      input#rename-pcbid(type="hidden" name="pcbid")
      input#rename-name(type="hidden" name="name")

    script.
      function renameCabinet(pcbid, currentName) {
        const newName = prompt("Enter new name for the cabinet:", currentName);
        if (newName && newName.trim() !== "" && newName !== currentName) {
          document.getElementById('rename-pcbid').value = pcbid;
          document.getElementById('rename-name').value = newName.trim();
          document.getElementById('rename-form').submit();
        }
      }

      function copyToClipboard(text, btn) {
        navigator.clipboard.writeText(text).then(() => {
          const originalIcon = btn.innerHTML;
          btn.innerHTML = '<span class="icon is-small has-text-success"><i class="mdi mdi-check"></i></span>';
          setTimeout(() => {
            btn.innerHTML = originalIcon;
          }, 2000);
        }).catch(err => {
          console.error('Failed to copy: ', err);
        });
      }
